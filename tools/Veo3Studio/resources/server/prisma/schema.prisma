generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64", "windows", "linux-musl"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model ProxySettings {
  id               Int       @id @default(1)
  enabled          Boolean   @default(false)
  providerType     String    @default("proxyxoay")
  apiKey           String?
  nhamang          String    @default("random")
  tinhthanh        String    @default("0")
  whitelist        String?
  autoRotate              Boolean   @default(true)
  rotationIntervalMinutes Int       @default(0)     // 0=tắt, 1,2,3,4,5,10,15 = phút giữa mỗi lần xoay
  forbiddenThreshold      Int       @default(3)     // số lần 403 trước khi auto-xoay (1-10)
  rotateOnProxyError      Boolean   @default(true)  // tự xoay khi proxy lỗi kết nối
  currentHttp             String?
  currentSocks5           String?
  currentExpiresAt        DateTime?
  lastFetchAt             DateTime?
  lastRotateError         String?
  updatedAt               DateTime  @updatedAt
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  name         String?
  avatar       String?
  googleId     String?           @unique
  role         UserRole          @default(USER)
  active       Boolean           @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  licenses     License[]
  sessions     Session[]
  activityLogs UserActivityLog[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  refreshToken String?  @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model License {
  id              String              @id @default(cuid())
  userId          String?
  licenseKey      String              @unique
  type            LicenseType         @default(STANDARD)
  status          LicenseStatus       @default(INACTIVE)
  machineId       String?
  activatedAt     DateTime?
  expiresAt       DateTime?
  maxActivations  Int                 @default(1)
  activationCount Int                 @default(0)
  features        Json?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User?               @relation(fields: [userId], references: [id])
  activations     LicenseActivation[]

  @@index([userId])
  @@index([licenseKey])
  @@index([machineId])
}

model LicenseActivation {
  id            String    @id @default(cuid())
  licenseId     String
  machineId     String
  machineName   String?
  ipAddress     String?
  activatedAt   DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())
  deactivatedAt DateTime?
  license       License   @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, machineId])
  @@index([licenseId])
  @@index([machineId])
}

model UserActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Profile {
  id                   String                    @id @default(cuid())
  name                 String
  description          String?
  accessToken          String?
  accessTokenExpires   DateTime?
  maxConcurrency       Int                       @default(5)
  dailyQuota           Int?
  runningJobs          Int                       @default(0)
  active               Boolean                   @default(true)
  proxyHost            String?
  proxyPort            Int?
  proxyUsername        String?
  proxyPassword        String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  apiKeys              ApiKey[]
  genNormalJobs        GenNormalJob[]
  genNormalProfiles    GenNormalProjectProfile[]

}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  key        String
  profileId  String?
  isActive   Boolean   @default(false)
  usageCount Int       @default(0)
  lastUsed   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  profile    Profile?  @relation(fields: [profileId], references: [id])

  @@index([profileId])
  @@index([isActive])
}





model ActivityLog {
  id        String   @id @default(cuid())
  category  String
  message   String
  data      Json?
  createdAt DateTime @default(now())
}





model GenNormalProject {
  id             String                    @id @default(cuid())
  name           String
  status         String                    @default("READY")
  paygateTier    String?
  source         String                    @default("normal")
  inputMethod    String                    @default("TEXT")
  aspectRatio    String                    @default("16:9")
  outputDir      String                    @default("D:/NOI CHUA VIDEO/1")
  concurrency    Int                       @default(10)
  batchSize      Int                       @default(1)
  delaySeconds   Int                       @default(3)
  videoModelKey      String?
  imageModelKey      String?
  autoDownload       Boolean               @default(false)
  autoUpscaleVideo   Boolean               @default(false)
  autoUpscaleImage   Boolean               @default(false)
  totalJobs      Int                       @default(0)
  completedJobs  Int                       @default(0)
  failedJobs     Int                       @default(0)
  processingJobs Int                       @default(0)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  startedAt      DateTime?
  completedAt    DateTime?
  jobs           GenNormalJob[]
  profiles       GenNormalProjectProfile[]
  pipelineItems  PipelineItem[]

  @@index([status])
  @@index([source])
}

model GenNormalProjectProfile {
  id            String           @id @default(cuid())
  projectId     String
  profileId     String
  veo3ProjectId String?
  createdAt     DateTime         @default(now())
  profile       Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  project       GenNormalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, profileId])
  @@index([projectId])
  @@index([profileId])
}

model GenNormalJob {
  id                        String           @id @default(cuid())
  projectId                 String
  profileId                 String
  prompt                    String
  jobIndex                  Int
  batchIndex                Int              @default(0) // Batch submission number (0-based); jobs created in the same "Tạo job" click share the same batchIndex
  mode                      String           @default("TEXT_TO_VIDEO")
  startImageMediaId         String?
  endImageMediaId           String?
  referenceImageMediaIds    Json?
  startImagePreviewUrl      String?
  endImagePreviewUrl        String?
  referenceImagePreviewUrls Json?
  status                    String           @default("DRAFT")
  progress                  Int              @default(0)
  providerJobId             String?
  sceneId                   String?
  veo3ProjectId             String?
  jobType                   String           @default("VIDEO") // VIDEO or IMAGE
  availableResolutions      Json?            // { "original": "url", "1080p": "url", "2k": "url", "4k": "url" }
  currentResolution         String?          @default("original") // Current active resolution
  upsamplingStatus          Json?            // { "1080p": "completed", "4k": "processing" }
  resultUrl                 String?
  videoBlob                 String?
  error                     String?
  retryCount                Int              @default(0)
  maxRetries                Int              @default(3)
  upsamplingJobId           String?
  isUpsampled               Boolean          @default(false)
  parentJobId               String?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  startedAt                 DateTime?
  completedAt               DateTime?
  pipelineItemId            String?
  profile                   Profile          @relation(fields: [profileId], references: [id])
  project                   GenNormalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([profileId])
  @@index([status])
  @@index([projectId, jobIndex])
  @@index([projectId, batchIndex])
  @@index([pipelineItemId])
}

model PipelineItem {
  id                     String           @id @default(cuid())
  projectId              String
  itemIndex              Int

  // Prompts
  imagePrompt            String           @default("")
  videoPrompt            String           @default("")

  // State machine: PENDING → IMAGE_GEN → SELECT_IMAGE → VIDEO_GEN → UPSCALE_IMAGE → UPSCALE_VIDEO → DOWNLOAD → COMPLETED | FAILED
  stage                  String           @default("PENDING")

  // Config per item
  aspectRatio            String           @default("16:9")
  videoModelKey          String?
  imageModelKey          String?
  autoUpscaleImage       Boolean          @default(false)
  imageUpscaleRes        String?          // "2K" | "4K"
  autoUpscaleVideo       Boolean          @default(false)
  videoUpscaleRes        String?          // "1080P" | "4K"
  autoPickImage          Boolean          @default(false)

  // Character/Scene references (JSON strings)
  characterImageMediaIds String?          // JSON: [{profileId, mediaId, previewUrl}]
  sceneImageMediaIds     String?          // JSON: [{profileId, mediaId, previewUrl}]

  // Job references (link to GenNormalJob)
  imageGenJobIds         String?          // JSON array of GenNormalJob ids
  selectedImageJobId     String?          // GenNormalJob.id of picked image
  videoGenJobId          String?          // GenNormalJob.id for IMAGE_TO_VIDEO
  imageUpscaleJobId      String?
  videoUpscaleJobId      String?

  // Results
  selectedImageMediaId   String?          // mediaId (providerJobId) of picked image
  finalImageUrl          String?
  finalVideoUrl          String?

  // Error & retry
  retryCount             Int              @default(0)
  maxRetries             Int              @default(3)
  lastError              String?
  originalPrompt         String?          // prompt before Gemini fix
  fixedPromptHistory     String?          // JSON: [{prompt, reason, timestamp}]

  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  project                GenNormalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([stage])
  @@index([projectId, itemIndex])
}

model QueueJob {
  id          String    @id
  type        String
  status      String    @default("queued")
  priority    Int       @default(0)
  profileId   String?
  data        String
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  result      String?
  error       String?
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  workflowId  String?
  stepId      String?

  @@index([status, priority, createdAt])
  @@index([profileId, status])
  @@index([workflowId])
  @@index([type, status])
}

model RateLimitLog {
  id        String   @id @default(cuid())
  profileId String
  timestamp DateTime @default(now())
  cost      Int      @default(1)

  @@index([profileId, timestamp])
}

model ProfileQuota {
  profileId   String   @id
  dailyLimit  Int
  usedToday   Int      @default(0)
  lastResetAt DateTime @default(now())

  @@index([lastResetAt])
}

model WorkflowExecution {
  id          String         @id
  name        String
  status      String         @default("running")
  userId      String?
  input       String
  output      String?
  error       String?
  createdAt   DateTime       @default(now())
  startedAt   DateTime       @default(now())
  completedAt DateTime?
  currentStep String?
  steps       WorkflowStep[]

  @@index([status, createdAt])
  @@index([name, status])
}

model WorkflowTemplate {
  id             String        @id @default(cuid())
  name           String
  description    String        @default("")
  definitionJson String        // Full WorkflowDefinition JSON
  thumbnail      String?
  isBuiltIn      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  runs           WorkflowRun[]
}

model WorkflowRun {
  id             String            @id @default(cuid())
  templateId     String?
  template       WorkflowTemplate? @relation(fields: [templateId], references: [id])
  definitionJson String            // Snapshot of workflow at run time
  globalInputs   String            @default("{}") // User-provided inputs JSON
  status         String            @default("PENDING") // PENDING | RUNNING | PAUSED | COMPLETED | FAILED | CANCELLED
  progress       Int               @default(0)
  nodeStates     String            @default("{}") // JSON: { nodeId: { status, output, error, progress } }
  outputPath     String?
  error          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  startedAt      DateTime?
  completedAt    DateTime?

  @@index([status])
  @@index([templateId])
  @@index([createdAt])
}

model BatchRun {
  id              String         @id @default(cuid())
  name            String?
  status          BatchRunStatus @default(PENDING)
  progress        Int            @default(0)
  config          Json?
  totalItems      Int            @default(0)
  completedItems  Int            @default(0)
  failedItems     Int            @default(0)
  processingItems Int            @default(0)
  result          Json?
  error           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  startedAt       DateTime?
  completedAt     DateTime?
  items           BatchItem[]

  @@index([status])
  @@index([createdAt])
}

model BatchItem {
  id          String             @id @default(cuid())
  batchId     String
  itemIndex   Int
  inputType   BatchItemInputType @default(IDEA)
  input       String
  status      BatchItemStatus    @default(PENDING)
  progress    Int                @default(0)
  workflowId  String?
  scriptId    String?
  projectId   String?
  resultUrl   String?
  result      Json?
  error       String?
  retryCount  Int                @default(0)
  maxRetries  Int                @default(3)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  batch       BatchRun           @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, itemIndex])
  @@index([status])
  @@index([workflowId])
}

model WorkflowStep {
  id             String            @id @default(cuid())
  workflowId     String
  stepId         String
  name           String
  status         String            @default("pending")
  input          String?
  output         String?
  error          String?
  progress       Int               @default(0)
  progressDetail String?
  startedAt      DateTime?
  completedAt    DateTime?
  workflow       WorkflowExecution @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, stepId])
  @@index([status])
}



// ─── Video Studio ───────────────────────────────────────

model StudioProject {
  id          String            @id @default(cuid())
  name        String
  type        String            // "video-dich" | "kich-ban-dai" | "storyboard"
  status      String            @default("DRAFT") // DRAFT | IN_PROGRESS | COMPLETED | FAILED
  currentStep Int               @default(0)
  config      String            @default("{}") // JSON: aspect ratio, output dir, profile IDs, etc.
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  steps       StudioStep[]
  characters  StudioCharacter[]
  locations   StudioLocation[]

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model StudioStep {
  id          String         @id @default(cuid())
  projectId   String
  stepIndex   Int
  stepType    String         // "input"|"transcribe"|"translate"|"tts"|"segment"|"image-gen"|"video-gen"|"assemble"|"export"|"rewrite"|"expand-idea"|"characters"|"storyboard"
  status      String         @default("PENDING") // PENDING | RUNNING | COMPLETED | FAILED | SKIPPED
  progress    Int            @default(0)
  inputData   String?        // JSON: input from user or previous step
  outputData  String?        // JSON: result of this step (file paths, text, segments...)
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  project     StudioProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, stepIndex])
  @@index([projectId])
  @@index([status])
}

model StudioCharacter {
  id              String        @id @default(cuid())
  projectId       String
  name            String
  description     String        @default("")
  promptEn        String        @default("") // English description for prompt generation
  referenceImages String?       // JSON: [{profileId, mediaId, previewUrl}]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  project         StudioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model StudioLocation {
  id              String        @id @default(cuid())
  projectId       String
  name            String
  description     String        @default("")
  promptEn        String        @default("") // English description for prompt generation
  referenceImages String?       // JSON: [{profileId, mediaId, previewUrl}]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  project         StudioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

