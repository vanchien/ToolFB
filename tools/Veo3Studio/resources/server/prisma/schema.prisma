// ============================================
// Storyboard Studio
// ============================================

model StoryboardProject {
  id             String   @id @default(cuid())
  name           String
  synopsis       String?  @default("")
  style          String?  @default("")
  aspectRatio    String   @default("16:9")
  status         String   @default("DRAFT")
  config         String?  // JSON: { profileId, modelKey, outputDir, ... }

  // Phase 1 — script writing settings
  styleId        String?  // Selected visual-style preset id (e.g. "3d_xuanhuan")
  language       String?  @default("Vietnamese")  // Chinese | English | Vietnamese | Japanese
  targetDuration String?  @default("auto")        // auto | 10s | 30s | 60s | ...
  sceneCount     String?  // auto | "1".."10"
  shotCount      String?  // auto | "3".."12" | custom number as string
  promptLanguage String?  @default("en")          // zh | en | zh+en
  rawScript      String?  // Raw pasted/generated script text
  parseStatus    String   @default("IDLE")        // IDLE | PARSING | READY | ERROR
  parseError     String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  characters     StoryboardCharacter[]
  locations      StoryboardLocation[]
  shots          StoryboardShot[]

  @@index([status])
}

model StoryboardCharacter {
  id              String   @id @default(cuid())
  projectId       String
  name            String
  description     String?
  imageUrl        String?  // Character sheet preview (reference image)
  mediaIds        String?  // JSON: { profileId: mediaId }

  // Phase 2 — calibration fields
  gender          String?
  age             String?
  personality     String?
  appearance      String?          // Human-readable appearance (VN)
  visualPromptEn  String?          // English visual prompt for image gen
  identityAnchors String?          // JSON: CharacterIdentityAnchors (6-layer)
  negativePrompt  String?          // JSON: { avoid: [], styleExclusions: [] }
  characterSheetUrls String?       // JSON: string[] (6-9 multi-angle reference URLs on white bg)
  calibrationStatus String @default("IDLE")  // IDLE | CALIBRATING | DONE | ERROR
  calibrationError  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project         StoryboardProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId])
}

model StoryboardLocation {
  id                String   @id @default(cuid())
  projectId         String
  name              String
  description       String?
  imageUrl          String?
  mediaIds          String?  // JSON: { profileId: mediaId }

  // Phase 2 — calibration fields
  timeOfDay         String?  // Day | Night | Dawn | Dusk
  atmosphere        String?
  visualPromptEn    String?
  architectureStyle String?
  lightingDesign    String?
  colorPalette      String?
  keyProps          String?  // JSON: string[]
  spatialLayout     String?
  eraDetails        String?
  calibrationStatus String  @default("IDLE")
  calibrationError  String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project           StoryboardProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId])
}

model StoryboardShot {
  id                  String   @id @default(cuid())
  projectId           String
  shotIndex           Int
  sceneText           String?
  imagePrompt         String?
  videoPrompt         String?
  cameraMotion        String?  @default("Static")
  duration            Int      @default(5)
  transition          String   @default("cut")
  characters          String?  // JSON: ["characterId1", ...]
  locationId          String?
  storyboardUrl       String?
  storyboardMediaIds  String?  // JSON: { profileId: mediaId }
  videoUrl            String?
  videoJobId          String?
  status              String   @default("DRAFT")

  // Phase 1 — writing extras (visible in UI)
  actionSummary       String?  // Hành động tóm tắt (VN)
  visualDescription   String?  // Mô tả hình ảnh chi tiết (VN)
  shotSize            String?  // Wide | Medium | Close-up | ECU | ...
  dialogue            String?
  ambientSound        String?
  soundEffect         String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project             StoryboardProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId])
  @@index([projectId, shotIndex])
}
